# 服务器配置
PORT=3000
NODE_ENV=development

# JWT 配置
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 数据库配置
DB_PATH=./data/requireagent.db

# 邮件配置（开发环境下会在控制台打印验证码）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@requireagent.com

# LLM 配置
# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 本地模型 (如 Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2

# 自定义中转 API（兼容 OpenAI 格式的第三方中转服务）
# 示例中转服务：https://api.openai-proxy.com/v1, https://api.closeai.com/v1 等
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=gpt-4o

# 默认 LLM 提供商 (openai, claude, deepseek, local, custom)
DEFAULT_LLM_PROVIDER=openai

# API 类型 (chat_completions 或 responses)
# chat_completions: 传统 Chat Completions API (/v1/chat/completions) - 默认
# responses: OpenAI 新版 Responses API (/v1/responses) - 适用于 Codex 等模型
# 注意：responses API 返回 SSE 流式格式，已自动处理
LLM_API_TYPE=chat_completions

# 文件存储
UPLOAD_DIR=./uploads
DOCUMENTS_DIR=./documents

# 文档生成配置
DOC_AUTO_THRESHOLD=50
DOC_SCHEDULE_CRON=0 0 * * *

# CORS 配置
CORS_ORIGIN=http://localhost:5173
